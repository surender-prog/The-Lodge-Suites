# ─── Supabase ──────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values from the Supabase
# project dashboard (Project Settings → API).
#
# Vite only exposes variables prefixed with `VITE_` to the client bundle, so
# the anon key is safe to ship — Row-Level Security policies in the database
# are the actual access boundary.
#
#   1. Create / pick the project at https://supabase.com/dashboard
#   2. Project Settings → API
#   3. Copy "Project URL" → VITE_SUPABASE_URL
#   4. Copy "anon" / "public" key → VITE_SUPABASE_ANON_KEY
#   5. Restart `npm run dev` — Vite reads env files only on boot
#
# DO NOT put the `service_role` key here. It bypasses RLS and is only for
# server-side code (e.g. an admin script or a serverless function).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
